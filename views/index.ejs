<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>Daily Inspiration</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #eef6ff, #f8fafc);
            min-height: 100vh;
            color: #1e293b;
        }

        .hero {
            padding: 70px 0 40px;
            text-align: center;
        }

        .hero h1 {
            font-size: 3rem;
            font-weight: 700;
            color: #0f172a;
        }

        .hero p {
            color: #64748b;
            font-size: 1rem;
        }

        .quote-card {
            border: none;
            border-radius: 20px;
            background: #fff;
            box-shadow: 0 10px 25px rgba(15, 23, 42, .08);
            transition: .3s ease;
            height: 100%;
        }

        .quote-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(59, 130, 246, .2);
        }

        .quote-icon {
            font-size: 60px;
            color: #2563eb;
            line-height: 1;
        }

        .quote-text {
            font-size: 1.1rem;
            font-style: italic;
            color: #334155;
            line-height: 1.8;
            min-height: 150px;
        }

        .author {
            color: #2563eb;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: .85rem;
        }

        .btn-custom {
            background: #2563eb;
            color: white;
            border: none;
            border-radius: 50px;
            padding: 12px 35px;
            font-weight: 600;
            transition: .3s;
        }

        .btn-custom:hover {
            background: #1d4ed8;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(37, 99, 235, .3);
        }

        hr {
            opacity: .15;
        }
    </style>

</head>

<body>

    <div class="container py-5">

        <!-- Header -->
        <div class="hero">

            <span class="badge rounded-pill bg-primary px-3 py-2 mb-3">
                ✨ Daily Inspiration
            </span>

            <h1>Inspirational Quotes</h1>

            <p>
                Temukan inspirasi baru setiap kali halaman dimuat.
            </p>

        </div>

        <!-- Quotes -->
        <div class="row g-4">

            <% quotes.forEach((quote,index)=> { %>

                <div class="col-lg-4 col-md-6">

                    <div class="card quote-card p-4">

                        <div class="quote-icon">
                            “
                        </div>

                        <div class="card-body px-0">

                            <p class="quote-text">
                                <%= quote.text %>
                            </p>

                            <hr>

                            <div class="d-flex justify-content-between align-items-center">

                                <span class="author">
                                    — <%= quote.author %>
                                </span>

                                <span class="badge bg-primary rounded-pill">
                                    #<%= index+1 %>
                                </span>

                            </div>

                        </div>

                    </div>

                </div>

                <% }) %>

        </div>

        <!-- Button -->
        <div class="text-center mt-5">

            <button onclick="window.location.reload()" class="btn btn-custom">
                🔄 Acak Kutipan
            </button>

        </div>

    </div>

</body>

</html>